{
  "name": "@jvnvr/acad-ts",
  "version": "0.0.10",
  "description": "TypeScript library to read and write AutoCAD DWG and DXF files. Forked from https://github.com/node-projects/acad-ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jvnvr/acad-ts.git"
  },
  "author": "Vasco Rola (https://github.com/jvnvr)",
  "contributors": [
    "Jochen Kühner <jochen.kuehner@gmx.de>"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jvnvr/acad-ts/issues"
  },
  "homepage": "https://github.com/jvnvr/acad-ts#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "autocad",
    "dwg",
    "dxf",
    "cad",
    "reader",
    "writer",
    "typescript"
  ],
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:test": "tsc -p tsconfig.vitest.json --noEmit",
    "prepublishOnly": "npm run build && npm run bundle",
    "bundle": "esbuild ./dist/index.js --format=esm --minify --platform=neutral --bundle --outfile=./dist/index-min.js",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version",
    "validate:version": "node scripts/validate-version.js"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
